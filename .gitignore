#################################
# Laravel core
#################################
/vendor/
/node_modules/
/public/storage
/storage/*.key
/storage/logs
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*

#################################
# Environment files (VERY IMPORTANT)
#################################
.env
.env.*
!.env.example

