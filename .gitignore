#################################
.phpunit.result.cache
Homestead.json
Homestead.yaml
auth.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

#################################
# Compiled assets
#################################
/public/build
/public/hot

#################################
# IDE / Editor files
#################################
.vscode/
.idea/
*.swp
*.swo

#################################
# Mac system files
#################################
.DS_Store

#################################
# MongoDB / local dev artifacts
#################################
*.log
dump.rdb

#################################
# Laravel Cloud / deployment
#################################
.laravel-cloud
.laravel/*
